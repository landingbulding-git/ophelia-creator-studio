---
import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Ophelia Creator Studio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Ophelia Studio</title>
	</head>
	<body class="bg-[#0a0a0a] text-white selection:bg-[#ff7a1a] selection:text-white">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--ophelia-orange: #ff7a1a;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
